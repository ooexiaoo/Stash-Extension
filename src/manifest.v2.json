{
  "manifest_version": 2,
  "name": "Stashed.in Extension",
  "version": "1.0.0",
  "description": "Save links directly to your Stashed.in boards from any webpage",
  "browser_specific_settings": {
    "gecko": {
      "id": "extension@stashed.in",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "activeTab",
    "storage",
    "https://stashlist-extension-api-production.wolfr13.workers.dev/*",
    "https://stashed.in/*"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Save to Stashed.in"
  },
  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
